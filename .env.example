# Shared
MONGODB_URI=mongodb://127.0.0.1:27017/mvidia
UPLOAD_DIR=./uploads

# api-user (default :3001)
API_USER_PORT=3001

# api-admin (default :3002)
API_ADMIN_PORT=3002
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
# Browser origin for web-admin Vite (CORS)
ADMIN_CORS_ORIGIN=http://localhost:5174

# packages/web (.env in web/ or root — Vite reads packages/web/.env)
# VITE_API_USER_BASE_URL=http://localhost:3001
# VITE_PUBLIC_SITE_URL=http://localhost:5173

# packages/web-admin
# VITE_API_ADMIN_BASE_URL=http://localhost:3002

# docker-build.sh (push на Docker Hub)
# DOCKERHUB_USER=your-dockerhub-username
# DOCKER_IMAGE_PREFIX=mvidia
# DOCKER_TAG=latest
