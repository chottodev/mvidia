# Shared (локальный npm run dev)
MONGODB_URI=mongodb://127.0.0.1:27017/mvidia
UPLOAD_DIR=./uploads

# Порты (локально и в docker-compose)
API_USER_PORT=3001
API_ADMIN_PORT=3002

# Ссылка на публичный сайт (сборка админки: колонка «открыть»)
USER_PUBLIC_SITE_URL=http://localhost:3001

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
# Только для dev: Vite web-admin на другом порту
ADMIN_CORS_ORIGIN=http://localhost:5174

# packages/web (локальный Vite)
# VITE_API_USER_BASE_URL=http://localhost:3001
# VITE_PUBLIC_SITE_URL=http://localhost:5173

# packages/web-admin (локальный Vite)
# VITE_API_ADMIN_BASE_URL=http://localhost:3002

# SERVE_UI=0 — отключить раздачу UI; UI_DIST_PATH — переопределить каталог dist
# В Docker UI: /app/ui (авто); локально: packages/web/dist или packages/web-admin/dist
